# Waffo sandbox credentials for the end-to-end tests.
#
# Copy this file to `.env` (gitignored) and fill in your sandbox values, then:
#   just e2e
# (or: cargo test --test e2e -- --ignored --nocapture)
#
# The .env file is loaded automatically by the e2e tests (via dotenvy).
#
# Key ownership (this trips people up):
#   - the API key + private key are YOURS (the merchant). You sign requests
#     with your private key.
#   - the public key is WAFFO's. You verify Waffo's response / webhook
#     signatures with it. (You never have Waffo's private key.)

# Your (merchant) API key.
WAFFO_MERCHANT_API_KEY=

# Your (merchant) private key, Base64 (PKCS#8) — single line, no quotes.
WAFFO_MERCHANT_PRIVATE_KEY=

# Waffo's public key, Base64 (X.509/SPKI) — single line.
WAFFO_PUBLIC_KEY=

# Your merchant id (auto-injected into requests).
WAFFO_MERCHANT_ID=

# SANDBOX (default) or PRODUCTION. Keep SANDBOX for these tests.
WAFFO_ENVIRONMENT=SANDBOX
